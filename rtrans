<!DOCTYPE html>
<html lang="ta">
<head>
    <meta charset="UTF-8">
    <title>Reflect TN - Live Election Overlay</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        /* கம்பீரமான எண்கள் மற்றும் ஆங்கில எழுத்துக்களுக்கான Oswald Font */
        @import url('https://fonts.googleapis.com/css2?family=Oswald:wght@700&display=swap');
        @font-face {
            font-family: 'Tamil039';
            src: url('https://cdn.lawtamil.in/font/Tamil039.woff2') format('woff2');
            font-weight: bold; font-style: normal;
        }

        * { box-sizing: border-box; }

        /* 1. Body 100% வெளிப்படையாக இருக்கும் (வீடியோ தெரிவதற்காக) */
        body, html {
            margin: 0; padding: 0; width: 1280px; height: 770px;
            background: transparent; 
            overflow: hidden;
            font-family: 'Oswald', 'Tamil039', sans-serif;
        }

        /* 720px-லிருந்து 770px ஆக மாற்றப்பட்டுள்ளது */
        .overlay-canvas { width: 1280px; height: 770px; position: relative; }

        /* 2. கிழிந்து வரும் பின்னணி (Tear Backgrounds) */
        .tear-bg {
            position: absolute; top: 0; width: 100%; height: 100%;
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
            z-index: 10;
        }

        /* Reflect TN சிவப்பு நிறம் */
        .tear-left {
            background: #19f radial-gradient(transparent, #02c);
            clip-path: polygon(0% 0%, 52% 0%, 49% 100%, 0% 100%);
            transform: translateX(-100%); /* ஆரம்பத்தில் மறைந்திருக்கும் */
            border-right: 5px solid #fff000;
        }

        /* Reflect TN நீல நிறம் */
        .tear-right {
            background: #19f radial-gradient(transparent, #02c);
            clip-path: polygon(49% 0%, 100% 0%, 100% 100%, 46% 100%);
            transform: translateX(100%); /* ஆரம்பத்தில் மறைந்திருக்கும் */
            border-left: 5px solid #fff000;
        }

        /* 3. 4-கட்ட நிலவரப் பலகை (Grid Content) */
        .grid-content {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr;
            gap: 25px; padding: 30px; 
            z-index: 20; 
            opacity: 0; transform: scale(0.8); /* ஆரம்பத்தில் மறைந்திருக்கும் */
            transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        }

        .quad {
            background: rgba(0, 0, 0, 0.85); backdrop-filter: blur(10px);
            border-radius: 20px; border: 2px solid rgba(255,255,255,0.2);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            box-shadow: 0 10px 25px rgba(0,0,0,0.6);
            padding: 15px 25px; 
        }

        /* --- Sattaviyal Layout --- */
        .q-sattaviyal { 
            border-color: #ffca70; 
            background: rgba(0, 26, 77, 0.95);
        }
        
        .title-row {
            display: flex; flex-direction: row; align-items: center; justify-content: center;
            gap: 20px; margin-bottom: 0px; 
        }
        
        .title-col {
            display: flex; flex-direction: column; align-items: center;
        }

        .q-sattaviyal .icon { font-size: 80px; color: #ffca70; animation: flipAction 4s infinite;}
        .q-sattaviyal .title { font-size: 55px; color: #ffca70; text-shadow: 0 4px 10px #000; margin: 0; line-height: 1.8;}
        
        .q-sattaviyal .subtitle { font-size: 20px; color: #fff; letter-spacing: 1px; margin-top: 2px; margin-bottom: 0; text-shadow: 0 2px 5px #000; }
        
        .q-sattaviyal .social-row { display: flex; gap: 20px; margin-top: 10px; margin-bottom: 5px; color: #fff; font-size: 24px; align-items: center;}
        .q-sattaviyal .social-row i { color: #ffca70; }
        
        .q-sattaviyal .slogan {
            font-size: 19px; color: #fff; text-align: center;
            margin-top: 5px; font-weight: bold; 
            line-height: 1.9; 
            border-top: 1px solid rgba(255,202,112,0.3); 
            padding-top: 15px; padding-bottom: 5px; 
            width: 90%;
        }

        /* --- Party Layouts --- */
        .q-dmk { border-color: #fff000; background: rgba(198, 2, 3, 0.95); }
        .q-admk { border-color: #fff000; background: rgba(0, 102, 0, 0.95); }
        .q-others { border-color: #fff; background: rgba(50, 50, 50, 0.95); }

        .party-data-row {
            display: flex; flex-direction: row; align-items: center; justify-content: center;
            gap: 40px; width: 100%; margin-bottom: 10px;
        }

        .logo-box { 
            width: 140px; height: 140px; 
            background: #fff; 
            border-radius: 50%; 
            border: 6px solid #fff; 
            box-shadow: 0 8px 15px rgba(0,0,0,0.5); 
            display: flex; align-items: center; justify-content: center;
            overflow: hidden; 
            padding: 0; 
        }
        
        .logo-box img { 
            width: 100%; height: 100%; 
            object-fit: contain; 
            transform: scale(1.1); 
        }

        .count { font-size: 120px; font-weight: 900; color: #fff; margin: 0; text-shadow: 0 6px 15px #000; line-height: 1; }
        
        .label { font-size: 36px; color: #fff000; text-transform: uppercase; font-weight: bold; margin-top: 5px; text-shadow: 0 3px 8px #000; }
        
        .others-text { font-size: 65px; color: #fff; font-weight: bold; margin: 0; text-shadow: 0 5px 15px #000; line-height: 1;}

        @keyframes flipAction { 0% { transform: perspective(400px) rotateY(0deg); } 40% { transform: perspective(400px) rotateY(180deg); } 80%, 100% { transform: perspective(400px) rotateY(360deg); } }

        /* =======================================
           ANIMATION TRIGGER CLASSES
        ======================================= */
        /* JS மூலம் 'active' கிளாஸ் சேர்க்கப்படும் போது... */
        .active .tear-left { transform: translateX(0); }
        .active .tear-right { transform: translateX(0); }
        .active .grid-content { opacity: 1; transform: scale(1); transition-delay: 0.5s; } /* பின்னணி வந்த 0.5 விநாடி கழித்து அட்டைகள் தோன்றும் */

    </style>
</head>
<body>

    <div class="overlay-canvas" id="main-canvas">
        
        <div class="tear-bg tear-left"></div>
        <div class="tear-bg tear-right"></div>

        <div class="grid-content">
            
            <div class="quad q-sattaviyal">
                <div class="title-row">
                    <div class="icon">⚖️</div>
                    <div class="title-col">
                        <h2 class="title">சட்டவியல்</h2>
                        <div class="subtitle">இது நீதியின் தேடல்</div>
                    </div>
                </div>
                <div class="social-row">
                    <i class="fa-brands fa-youtube"></i>
                    <i class="fa-brands fa-facebook"></i>
                    <i class="fa-brands fa-instagram"></i>
                    <span>@JurisprudenceTamil</span>
                </div>
                <div class="slogan">
                    சிக்கலான சட்ட நுணுக்கங்களை எளிமையாகப்<br>புரிந்து கொள்ள இணைந்திடுவீர்.
                </div>
            </div>

            <div class="quad q-dmk">
                <div class="party-data-row">
                    <div class="logo-box">
                        <img src="https://tv.rtbs.in/images/dmk.png" alt="DMK">
                    </div>
                    <div class="count" id="dmk-count">0</div>
                </div>
                <div class="label">Leading / முன்னிலை</div>
            </div>

            <div class="quad q-admk">
                <div class="party-data-row">
                    <div class="logo-box">
                        <img src="https://tv.rtbs.in/images/aiadmk.png" alt="ADMK">
                    </div>
                    <div class="count" id="admk-count">0</div>
                </div>
                <div class="label">Leading / முன்னிலை</div>
            </div>

            <div class="quad q-others">
                <div class="party-data-row">
                    <div class="others-text">OTHERS</div>
                    <div class="count" id="others-count">0</div>
                </div>
                <div class="label">TVK / NTK / OTHERS</div>
            </div>
            
        </div>
    </div>

    <script>
        // Notepad-ல் உள்ள டேட்டாவை எடுத்து அப்டேட் செய்யும் ஃபங்க்ஷன்
        function loadLocalData() {
            var oldScript = document.getElementById('local-data-script');
            if (oldScript) oldScript.remove();

            var script = document.createElement('script');
            script.id = 'local-data-script';
            script.src = 'data.js?t=' + new Date().getTime(); // Cache Buster
            
            script.onload = function() {
                // டேட்டா லோட் ஆனதும் எண்களை மாற்றுதல்
                document.getElementById('dmk-count').innerText = typeof DMK !== 'undefined' ? DMK : "0";
                document.getElementById('admk-count').innerText = typeof ADMK !== 'undefined' ? ADMK : "0";
                document.getElementById('others-count').innerText = typeof OTHERS !== 'undefined' ? OTHERS : "0";
            };

            document.head.appendChild(script);
        }

        // அனிமேஷனை இயக்குவதற்கான ஃபங்க்ஷன் (20 விநாடிகள்)
        function triggerElectionStatus() {
            const canvas = document.getElementById('main-canvas');
            
            // 1. திரைக்குள் வருகிறது (Active)
            canvas.classList.add('active');

            // 2. சரியாக 20 விநாடிகள் கழித்துத் திரையை விட்டு வெளியேறுகிறது
            setTimeout(() => {
                canvas.classList.remove('active');
            }, 20000);
        }

        // --- Main Execution Logic ---
        
        // சிஸ்டம் தொடங்கியதும் முதலில் டேட்டாவை லோட் செய்கிறோம்
        loadLocalData();

        // 1 நிமிடம் (60,000 ms) காத்திருந்து முதல் அனிமேஷனைத் தொடங்குகிறோம்
        setTimeout(() => {
            
            // முதலில் டேட்டாவை Refresh செய்கிறோம்
            loadLocalData();
            
            // பிறகு அனிமேஷனைக் காட்டுகிறோம்
            triggerElectionStatus();
            
            // அதன் பிறகு ஒவ்வொரு 1 நிமிடத்திற்கும் (60,000 ms) ஒரு முறை தொடர்ந்து செயல்படும் (Loop)
            setInterval(() => {
                loadLocalData();
                triggerElectionStatus();
            }, 60000);

        }, 60000); // 1 நிமிடக் காத்திருப்பு

    </script>
</body>
</html>
